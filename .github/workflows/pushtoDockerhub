name: Node.js CI/CD

on:
  push:
    branches:
      - main

jobs:
  build-and-deploy:
    runs-on: ubuntu-latest

    steps:
      # 1. Clone Repository
      - name: Checkout Code
        uses: actions/checkout@v4

      # 2. Setup Node.js
      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: 22

      # 3. Install Dependencies
      - name: Install Dependencies
        run: npm ci

      # 4. Build TypeScript
      - name: Build Project
        run: npm run build

      # 5. Build Docker Image
      - name: Build Docker Image
        run: docker build -t my-node-app .

      # 6. Login DockerHub
      - name: Login to DockerHub
        uses: docker/login-action@v3
        with:
          username: ${{ secrets.DOCKER_USERNAME }}
          password: ${{ secrets.DOCKER_PASSWORD }}

      # 7. Tag Docker Image
      - name: Tag Image
        run: docker tag my-node-app ${{ secrets.DOCKER_USERNAME }}/my-node-app:latest

      # 8. Push Docker Image
      - name: Push Docker Image
        run: docker push ${{ secrets.DOCKER_USERNAME }}/my-node-app:latest
# I used GitHub Actions for CI/CD automation. Whenever code is pushed to the main branch, the workflow automatically installs dependencies, builds the TypeScript project, creates a Docker image, logs into DockerHub using GitHub Secrets, and pushes the production-ready image.
